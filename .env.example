PORT=3000
LOG_LEVEL=info
WEBHOOK_API_KEY=local_test_key_123

# Public HTTPS base for Vapi tools (no trailing slash).
# Demo: https://your-service.onrender.com  |  Local tunnel: https://….trycloudflare.com
# PUBLIC_BASE_URL=
# Optional: separate key for Orders Hub UI API; defaults to WEBHOOK_API_KEY
# ORDERS_HUB_API_KEY=
# Local only: skip x-api-key for Orders Hub JSON routes (do not enable in production)
# ORDERS_HUB_ALLOW_NO_AUTH=true
# Estimated takeout quote (minutes) used for due time on the hub snapshot
# QUOTE_MINUTES_TAKEOUT=20
# Optional: sales tax % for /tools/estimate_cart (e.g. 8.875). Omit for subtotal-only estimates.
# ESTIMATE_TAX_RATE_PERCENT=
MENU_CACHE_TTL_MS=60000
RESTAURANT_TIMEZONE=America/New_York
BUSINESS_HOURS_OPEN=11:30
BUSINESS_HOURS_CLOSE=21:30

# test = no Toast API calls, live = send to Toast
ORDER_MODE=test

# Override only if Toast changes host
TOAST_BASE_URL=https://ws-sandbox-api.eng.toasttab.com

# Required only when ORDER_MODE=live
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID=
